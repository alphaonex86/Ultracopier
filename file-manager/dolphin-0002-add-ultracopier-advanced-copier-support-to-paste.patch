+static void sendRawOrderList(const QStringList &order, QLocalSocket &socket, int idNextOrder)
+{
+    QByteArray block;
+    QDataStream out(&block, QIODevice::WriteOnly);
+    out.setVersion(QDataStream::Qt_4_4);
+    out << int(0);
+    out << idNextOrder;
+    out << order;
+    out.device()->seek(0);
+    out << block.size();
+    do {
+        QByteArray blockToSend = block.left(32 * 1024); // 32KB
+        block.remove(0, blockToSend.size());
+        socket.write(blockToSend);
+    } while (block.size());
+}
